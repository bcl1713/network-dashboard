# Copy to .env and fill in real values. Never commit .env.
# Shared across docker-compose.yml.

TZ=America/New_York

# Shared API token enforced by the engine and sent by the UI + Fluent Bit.
# Generate with: openssl rand -hex 32
ENGINE_API_TOKEN=replace-me-with-32-bytes-hex

# Engine
ENGINE_DB_PATH=/data/filters.db
ENGINE_RING_SIZE=750
ENGINE_ALLOW_SID_ONLY=false
ENGINE_LOG_LEVEL=INFO
ENGINE_LOKI_URL=http://loki:3100
ENGINE_LOKI_TENANT=filtered

# UI
UI_LOG_LEVEL=INFO
UI_PAGE_SIZE=50
UI_ENGINE_BASE_URL=http://engine:8000

# Grafana
GF_ADMIN_PASSWORD=admin

# Host port mappings (override per-host if needed).
ENGINE_HOST_PORT=8081
UI_HOST_PORT=8082
LOKI_HOST_PORT=3100
GRAFANA_HOST_PORT=3000
FLUENTBIT_SYSLOG_PORT=5140
FLUENTBIT_METRICS_PORT=2020
