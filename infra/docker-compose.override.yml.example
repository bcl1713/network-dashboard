# Copy to docker-compose.override.yml for local development.
# Compose auto-loads this file when present.

services:
  engine:
    build:
      target: base
    volumes:
      - ../services/engine/app:/app/app:ro
      - ../services/engine/migrations:/app/migrations:ro
      - ../services/engine/scripts:/app/scripts:ro
    command: ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  ui:
    volumes:
      - ../services/ui/app:/app/app:ro
      - ../services/ui/templates:/app/templates:ro
      - ../services/ui/static:/app/static:ro
    command: ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
